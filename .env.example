# --- Frontend (Publicly Accessible) ---
# Prefix with VITE_ to make them available in the browser code
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Backend (Private/Secret) ---
# These are only accessible in /api routes. DO NOT prefix with VITE_
API_KEY=AIzaSy... (Your Google Gemini API Key)
CLERK_SECRET_KEY=sk_test_... (Your Clerk Secret Key)

# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Google Sheets Service Account Credentials
SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Cron Job Security
CRON_SECRET=your_random_secret
